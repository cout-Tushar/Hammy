{
  "name": "tushar_hammy",
  "version": "1.0.0",
  "description": "AI-powered CLI tool for API testing, request generation, API review, response explanation, and collection management from the terminal.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "hammy": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "cli",
    "api",
    "api-testing",
    "rest-api",
    "developer-tools",
    "typescript",
    "nodejs",
    "terminal",
    "axios",
    "commander",
    "ai",
    "groq",
    "api-generator",
    "api-review",
    "api-explain",
    "collections"
  ],
  "author": "Tushar Mishra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cout-Tushar/Hammy.git"
  },
  "homepage": "https://github.com/cout-Tushar/Hammy#readme",
  "bugs": {
    "url": "https://github.com/cout-Tushar/Hammy/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "preferGlobal": true,
  "dependencies": {
    "axios": "^1.15.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
